<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Group for centering and subtle movement effect (simulated by positioning) -->
    <group
        android:translateX="0"
        android:translateY="0">

        <!-- Glassy Ledger Background (Base) -->
        <!-- Left Page -->
        <path android:pathData="M54,42 L28,42 C25,42 24,44 24,48 L24,76 C24,80 25,82 28,82 L54,82 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="24"
                    android:startY="42"
                    android:endX="54"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0" android:color="#33FFFFFF" />
                    <item android:offset="1" android:color="#11FFFFFF" />
                </gradient>
            </aapt:attr>
        </path>
        <!-- Right Page -->
        <path android:pathData="M54,42 L80,42 C83,42 84,44 84,48 L84,76 C84,80 83,82 80,82 L54,82 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="54"
                    android:startY="42"
                    android:endX="84"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0" android:color="#44FFFFFF" />
                    <item android:offset="1" android:color="#22FFFFFF" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Glassy Edge Highlights for Ledger -->
        <path
            android:strokeColor="#66FFFFFF"
            android:strokeWidth="0.5"
            android:pathData="M28,42 L54,42 L80,42 C83,42 84,44 84,48 L84,76 C84,80 83,82 80,82 L54,82 L28,82 C25,82 24,80 24,76 L24,48 C24,44 25,42 28,42 Z" />

        <!-- Ledger Content Lines (Subtle) -->
        <path android:fillColor="#44CBD5E1" android:pathData="M30,50 h16 v2 h-16 z" />
        <path android:fillColor="#44CBD5E1" android:pathData="M30,58 h12 v2 h-12 z" />
        <path android:fillColor="#44CBD5E1" android:pathData="M30,66 h18 v2 h-18 z" />
        <path android:fillColor="#4494A3B8" android:pathData="M62,50 h16 v2 h-16 z" />
        <path android:fillColor="#4494A3B8" android:pathData="M62,58 h14 v2 h-14 z" />
        <path android:fillColor="#4494A3B8" android:pathData="M62,66 h10 v2 h-10 z" />

        <!-- Metallic Staff (Caduceus) -->
        <path android:pathData="M52.5,24 h3 v58 h-3 z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="52.5"
                    android:startY="24"
                    android:endX="55.5"
                    android:endY="82"
                    android:type="linear">
                    <item android:offset="0" android:color="#FDE68A" />
                    <item android:offset="0.5" android:color="#F59E0B" />
                    <item android:offset="1" android:color="#B45309" />
                </gradient>
            </aapt:attr>
        </path>
        <path android:pathData="M54,20 A3.5,3.5 0 1 1 53.9,20">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:centerX="54"
                    android:centerY="20"
                    android:gradientRadius="3.5"
                    android:type="radial">
                    <item android:offset="0" android:color="#FDE68A" />
                    <item android:offset="1" android:color="#F59E0B" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Wings with Glossy Feel -->
        <path android:pathData="M54,26 C43,21 34,26 31,34 C37,35 46,31 54,30 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="31"
                    android:startY="21"
                    android:endX="54"
                    android:endY="34"
                    android:type="linear">
                    <item android:offset="0" android:color="#FDE68A" />
                    <item android:offset="1" android:color="#F59E0B" />
                </gradient>
            </aapt:attr>
        </path>
        <path android:pathData="M54,26 C65,21 74,26 77,34 C71,35 62,31 54,30 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="77"
                    android:startY="21"
                    android:endX="54"
                    android:endY="34"
                    android:type="linear">
                    <item android:offset="0" android:color="#FDE68A" />
                    <item android:offset="1" android:color="#F59E0B" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Emerald Glass Snakes -->
        <path
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M46,74 C46,68 62,66 62,60 C62,54 46,52 46,46 C46,40 62,38 62,34">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="46"
                    android:startY="34"
                    android:endX="62"
                    android:endY="74"
                    android:type="linear">
                    <item android:offset="0" android:color="#34D399" />
                    <item android:offset="0.5" android:color="#10B981" />
                    <item android:offset="1" android:color="#065F46" />
                </gradient>
            </aapt:attr>
        </path>
        <path
            android:strokeWidth="2.5"
            android:strokeLineCap="round"
            android:fillColor="#00000000"
            android:pathData="M62,74 C62,68 46,66 46,60 C46,54 62,52 62,46 C62,40 46,38 46,34">
            <aapt:attr name="android:strokeColor">
                <gradient
                    android:startX="62"
                    android:startY="34"
                    android:endX="46"
                    android:endY="74"
                    android:type="linear">
                    <item android:offset="0" android:color="#34D399" />
                    <item android:offset="0.5" android:color="#10B981" />
                    <item android:offset="1" android:color="#065F46" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Snake Heads -->
        <path android:fillColor="#10B981" android:pathData="M60,34 A2,2 0 1 1 59.9,34" />
        <path android:fillColor="#10B981" android:pathData="M48,34 A2,2 0 1 1 47.9,34" />

        <!-- Glass Reflection Shine (The "Flux" Feel) -->
        <path android:pathData="M24,48 L84,48 L84,52 L24,60 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="24"
                    android:startY="48"
                    android:endX="84"
                    android:endY="60"
                    android:type="linear">
                    <item android:offset="0" android:color="#00FFFFFF" />
                    <item android:offset="0.5" android:color="#22FFFFFF" />
                    <item android:offset="1" android:color="#00FFFFFF" />
                </gradient>
            </aapt:attr>
        </path>

        <!-- Top Reflection Diagonal -->
        <path android:pathData="M40,20 L80,60 L70,70 L30,30 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:startX="40"
                    android:startY="20"
                    android:endX="80"
                    android:endY="70"
                    android:type="linear">
                    <item android:offset="0" android:color="#00FFFFFF" />
                    <item android:offset="0.5" android:color="#11FFFFFF" />
                    <item android:offset="1" android:color="#00FFFFFF" />
                </gradient>
            </aapt:attr>
        </path>

    </group>

</vector>
